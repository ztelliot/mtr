FROM --platform=$BUILDPLATFORM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal

ARG TARGETOS
ARG TARGETARCH
ARG TARGETVARIANT
ARG VERSION=dev
ARG COMMIT=
ARG BUILT_AT=
RUN apk add --no-cache ca-certificates && \
    set -eux; \
    targetos="${TARGETOS:-linux}"; \
    targetarch="${TARGETARCH:-$(go env GOARCH)}"; \
    goarm="${TARGETVARIANT#v}"; \
    if [ "${targetarch}" = "arm" ] && [ -n "${goarm}" ]; then \
      GOOS="${targetos}" GOARCH="${targetarch}" GOARM="${goarm}" CGO_ENABLED=0 go build -trimpath -ldflags "-s -w -X github.com/ztelliot/mtr/internal/version.Version=${VERSION} -X github.com/ztelliot/mtr/internal/version.Commit=${COMMIT} -X github.com/ztelliot/mtr/internal/version.BuiltAt=${BUILT_AT}" -o /out/mtr-server ./cmd/server; \
    else \
      GOOS="${targetos}" GOARCH="${targetarch}" CGO_ENABLED=0 go build -trimpath -ldflags "-s -w -X github.com/ztelliot/mtr/internal/version.Version=${VERSION} -X github.com/ztelliot/mtr/internal/version.Commit=${COMMIT} -X github.com/ztelliot/mtr/internal/version.BuiltAt=${BUILT_AT}" -o /out/mtr-server ./cmd/server; \
    fi

FROM scratch
ARG VERSION=dev
ARG COMMIT=
ARG BUILT_AT=
LABEL org.opencontainers.image.title="mtr-server" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${COMMIT}" \
      org.opencontainers.image.created="${BUILT_AT}"
COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=build /out/mtr-server /usr/local/bin/mtr-server
COPY configs/server.yaml /etc/mtr/server.yaml
EXPOSE 8080 8443
ENTRYPOINT ["/usr/local/bin/mtr-server"]
CMD ["-config", "/etc/mtr/server.yaml"]
